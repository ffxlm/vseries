# API URL - The backend endpoint
# Production example: https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Site URL - Your actual domain
# Production example: https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only admin JWT secret. Must match backend JWT_SECRET.
# Do not prefix this with NEXT_PUBLIC_.
JWT_SECRET=your_super_secret_key_here
